# ═════════════════════════════════════════════════════════════════════

if __name__ == "__main__":
    print("\nGenerando diagramas draw.io...\n")
    gen_class_diagram()
    gen_vi_flowchart()
    gen_pi_flowchart()
    gen_component_diagram()
    gen_sequence_diagram()
    print("\nListo. Archivos .drawio generados en la carpeta diagramas/")
